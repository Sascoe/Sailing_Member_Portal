rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------
    function signedIn() {
      return request.auth != null;
    }

    function myUid() {
      return request.auth.uid;
    }

    function myEmail() {
      return request.auth.token.email;
    }

    function isNUEmail() {
      return signedIn()
        && myEmail() != null
        && myEmail().matches('.*@u\\.northwestern\\.edu$');
    }

    function userDoc(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function hasPosition(pos) {
      return signedIn()
        && (userDoc(myUid()).positions != null)
        && userDoc(myUid()).positions.hasAny([pos]);
    }

    function myRole() {
      return signedIn() ? userDoc(myUid()).role : null;
    }

    function isChair() {
      return hasPosition("recruitment_chair");
    }

    function isMember() {
      return myRole() == "member";
    }

    function packetsReleased() {
      return exists(/databases/$(database)/documents/settings/global)
        && get(/databases/$(database)/documents/settings/global).data.packetsReleased == true;
    }

    function memberCanAccessProspie(prospieUid) {
      return packetsReleased()
        || (
          isMember()
          && exists(/databases/$(database)/documents/stage1Queue/$(prospieUid))
          && get(/databases/$(database)/documents/stage1Queue/$(prospieUid)).data.claimedBy == myUid()
          && get(/databases/$(database)/documents/stage1Queue/$(prospieUid)).data.state == "claimed"
        );
    }

    function isRecruitmentChair() {
      return signedIn()
      && userDoc(request.auth.uid).positions.hasAny(["recruitment_chair"]);
    }

    

    // ---------- Users ----------
    match /users/{uid} {
      allow read: if signedIn() && (uid == myUid() || isChair());

      // NU users can create their own user doc, but only as role="prospie"
      allow create: if signedIn()
        && uid == myUid()
        && isNUEmail()
        && request.resource.data.role == "prospie"
        && request.resource.data.email == myEmail();

      // User can update their own non-role fields; chair can update anything (including role)
      allow update: if signedIn() && (
        isChair()
        || (
          uid == myUid()
          && request.resource.data.role == resource.data.role
          && request.resource.data.email == resource.data.email
        )
      );

      allow delete: if false;
    }

    // ---------- Settings ----------
    match /settings/{docId} {
      allow read: if signedIn();
      allow write: if isChair();
    }
    match /settings/{docId} {
      allow read: if signedIn(); // members can read which stage is active

    // Only recruitment chairs can update settings/global
      allow update: if docId == "global" && isChair();

    // Usually you don't want members creating/deleting settings docs
      allow create, delete: if false;
    }

    // ---------- Prospies ----------
    match /prospies/{prospieUid} {
      allow read: if isChair()
        || (signedIn() && prospieUid == myUid())
        || memberCanAccessProspie(prospieUid);

      allow create: if signedIn()
        && prospieUid == myUid()
        && isNUEmail()
        && myRole() == "prospie";

      allow update: if isChair()
        || (signedIn() && prospieUid == myUid() && myRole() == "prospie");

      allow delete: if isChair();
    }

    match /prospies/{prospieId} {
      allow read: if hasPosition("recruitment_chair");
    }

    match /prospies/{prospieId} {
      allow create, read, update: if signedIn() && request.auth.uid == prospieId;
      allow delete: if false;
    }

    match /prospies/{prospieId} {
      // Chair can read all prospies
      allow read: if isRecruitmentChair();

      // Prospie can read/write their own doc
      allow create, read, update: if signedIn() && request.auth.uid == prospieId;

      allow delete: if false;
    }

    allow update: if isChair()
      && request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(["stage1Decision","stage1DecisionUpdatedAt","stage1DecisionUpdatedBy"]);


// ---------- Stage 1 Sailing Queue ----------
match /stage1SailingQueue/{prospieUid} {
  allow read: if isChair() || isMember() || (signedIn() && prospieUid == myUid());

  // Prospie can check in to sailing queue
  allow create: if signedIn()
    && prospieUid == myUid()
    && myRole() == "prospie"
    && isNUEmail()
    && request.resource.data.status == "waiting";

  // Prospie can leave queue; chair can also delete
  allow delete: if isChair() || (signedIn() && prospieUid == myUid());

  // Member claim waiting -> claimed; chairs can update
  allow update: if isChair()
    || (isMember()
      && resource.data.status == "waiting"
      && request.resource.data.status == "claimed"
      && request.resource.data.claimedBy == myUid()
    );
}

// ---------- Stage 1 Personality Queue ----------
match /stage1PersonalityQueue/{prospieUid} {
  allow read: if isChair() || isMember() || (signedIn() && prospieUid == myUid());

  // Only members/chairs can create personality queue entries
  // (these get created when sailing interview is completed)
  allow create: if isChair() || isMember();

  allow delete: if isChair(); // usually only chairs (or your completion transaction) should remove

  allow update: if isChair()
    || (isMember()
      && resource.data.status == "waiting"
      && request.resource.data.status == "claimed"
      && request.resource.data.claimedBy == myUid()
    );
}




    // ---------- Interviews ----------
    match /prospies/{prospieUid}/interviews/{interviewId} {
      allow read: if isChair()
        || (signedIn() && prospieUid == myUid())
        || (isMember() && memberCanAccessProspie(prospieUid));

      allow create: if isChair()
        || (
          isMember()
          && memberCanAccessProspie(prospieUid)
          && request.resource.data.stage == 1
        );

      allow update, delete: if isChair();
    }

    // ---------- Default deny ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

